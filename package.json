{
  "name": "dashboard-pcm-cloudflare",
  "version": "123.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run vite:sync && vite",
    "build": "npm run build:vite",
    "build:vite": "npm run vite:sync && vite build && node tools/postbuild-vite.cjs",
    "build:legacy": "node tools/build-dist.cjs",
    "preview": "npm run build:vite && vite preview",
    "test": "node --test tests/*.test.cjs",
    "test:python": "python -m pytest tools/tests -q",
    "audit:project": "node tools/audit-project.cjs",
    "verify": "npm run audit:project && npm test && npm run test:python && npm run build:vite",
    "verify:legacy": "npm run audit:project && npm test && npm run test:python && npm run build:legacy",
    "vite:sync": "node tools/prepare-vite-public.cjs",
    "typecheck:react": "tsc -p tsconfig.react.json --noEmit",
    "verify:react-preview": "npm run typecheck:react && npm run build:vite",
    "deploy:pages": "npx wrangler@4.112.0 pages deploy dist-vite"
  },
  "devDependencies": {
    "vite": "^8.1.5",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "5.7.2"
  },
  "engines": {
    "node": ">=20.19.0 <21 || >=22.12.0"
  },
  "type": "module",
  "dependencies": {
    "lucide-react": "0.468.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "packageManager": "npm@10.9.8"
}
